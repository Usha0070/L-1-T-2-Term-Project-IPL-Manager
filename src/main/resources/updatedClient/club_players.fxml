<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demonew.updatedClient.ClubPlayersController"
      spacing="20" alignment="CENTER" prefWidth="900" prefHeight="900"
      style="-fx-background-color: linear-gradient(to bottom, #1E3C72, #2A5298); -fx-padding: 40;">

    <!-- Title -->
    <Label text="MY CLUB PLAYERS"
           style="-fx-font-family: 'Arial'; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />

    <!-- Search Field -->
    <TextField fx:id="searchField" promptText="Search Players"
               style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5;
                      -fx-border-width: 2; -fx-font-size: 12px; -fx-pref-width: 600;" />

    <!-- TableView -->
    <TableView fx:id="playersTableView" prefWidth="750" prefHeight="600"
               style="-fx-background-color: rgba(0, 50, 100, 0.6); -fx-border-color: white;
                      -fx-border-radius: 10; -fx-border-width: 2; -fx-font-family: 'Arial';
                      -fx-font-size: 12px; -fx-text-fill: white;">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <!-- Columns will be dynamically added in the controller -->
        </columns>
    </TableView>

    <!-- Back Button -->
    <Button text="Back" onAction="#goBack"
            style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;
                   -fx-font-weight: bold; -fx-padding: 10 20; -fx-border-radius: 5;" />
</VBox>
