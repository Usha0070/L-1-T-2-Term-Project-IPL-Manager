<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17.0.6" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demonew.updatedClient.StatController"
      spacing="20" alignment="CENTER" prefWidth="900" prefHeight="900"
      style="-fx-background-color: linear-gradient(to bottom, #1E3C72, #2A5298); -fx-padding: 40;">

    <!-- Title -->
    <Label text="STATISTICS"
           style="-fx-font-family: 'Arial'; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />

    <!-- Highest Attributes Section -->
    <Label text="HIGHEST ATTRIBUTES"
           style="-fx-font-family: 'Arial'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;" />

    <TableView fx:id="highestAttributesTable" prefWidth="700" prefHeight="300"
               style="-fx-background-color: rgba(0, 50, 100, 0.6); -fx-border-color: white;
                      -fx-border-radius: 10; -fx-border-width: 2; -fx-font-family: 'Arial';
                      -fx-font-size: 14px; -fx-text-fill: white;">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- Lowest Attributes Section -->
    <Label text="LOWEST ATTRIBUTES"
           style="-fx-font-family: 'Arial'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;" />

    <TableView fx:id="lowestAttributesTable" prefWidth="700" prefHeight="300"
               style="-fx-background-color: rgba(0, 50, 100, 0.6); -fx-border-color: white;
                      -fx-border-radius: 10; -fx-border-width: 2; -fx-font-family: 'Arial';
                      -fx-font-size: 14px; -fx-text-fill: white;">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- Back Button -->
    <Button text="Back" onAction="#goBack"
            style="-fx-background-color: #4CAF50; -fx-text-fill: white;
                   -fx-font-family: 'Arial'; -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-padding: 10 20; -fx-border-radius: 5;" />

</VBox>
