<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="900" prefWidth="900" spacing="20" style="-fx-background-color: linear-gradient(to bottom, #1E3C72, #2A5298); -fx-padding: 40;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demonew.updatedViewer.ViewerDashboardController">
   <ImageView fitHeight="167.0" fitWidth="387.0" pickOnBounds="true" preserveRatio="true">
      <image>
         <Image url="@../Images/newIPLImage.jpg" />
      </image>
   </ImageView>

    <Label fx:id="welcomeLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" text="WELCOME TO VIEWER DASHBOARD" />

    <Button onAction="#openAllPlayersList" style="-fx-background-color: #2A5298; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-border-color: white; -fx-border-radius: 5; -fx-border-width: 2; -fx-padding: 10 20; -fx-cursor: hand; -fx-pref-width: 300;" text="VIEW ALL PLAYERS" />

    <Button onAction="#openClubWisePlayerCount" style="-fx-background-color: #2A5298; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-border-color: white; -fx-border-radius: 5; -fx-border-width: 2; -fx-padding: 10 20; -fx-cursor: hand; -fx-pref-width: 300;" text="CLUB WISE PLAYER COUNT" />

    <Button onAction="#openCountryWisePlayerCount" style="-fx-background-color: #2A5298; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-border-color: white; -fx-border-radius: 5; -fx-border-width: 2; -fx-padding: 10 20; -fx-cursor: hand; -fx-pref-width: 300;" text="COUNTRY WISE PLAYER COUNT" />

    <Button onAction="#openPlayerFilter" style="-fx-background-color: #2A5298; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-border-color: white; -fx-border-radius: 5; -fx-border-width: 2; -fx-padding: 10 20; -fx-cursor: hand; -fx-pref-width: 300;" text="PLAYER FILTER" />

    <Button onAction="#openStats" style="-fx-background-color: #2A5298; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-border-color: white; -fx-border-radius: 5; -fx-border-width: 2; -fx-padding: 10 20; -fx-cursor: hand; -fx-pref-width: 300;" text="STATISTICS" />

</VBox>
