<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demonew.updatedViewer.PlayerFilterController"
      alignment="CENTER" spacing="20" prefWidth="900" prefHeight="900"
      style="-fx-background-color: linear-gradient(to bottom, #1E3C72, #2A5298); -fx-padding: 30;">

    <!-- Title -->
    <Label text="PLAYER FILTER"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" />

    <!-- Input Fields -->
    <GridPane hgap="20" vgap="15" alignment="CENTER"
              style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-padding: 20; -fx-border-color: white; -fx-border-width: 2; -fx-border-radius: 10;">
        <Label text="Name:" style="-fx-text-fill: white;" />
        <TextField fx:id="nameField" promptText="Enter name"
                   style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5;" />

        <Label text="Country:" GridPane.columnIndex="1" style="-fx-text-fill: white;" />
        <TextField fx:id="countryField" promptText="Enter country" GridPane.columnIndex="2"
                   style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5;" />

        <Label text="Age:" GridPane.rowIndex="1" style="-fx-text-fill: white;" />
        <TextField fx:id="ageField" promptText="Enter age" GridPane.rowIndex="1"
                   style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5;" />

        <Label text="Height:" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-text-fill: white;" />
        <TextField fx:id="heightField" promptText="Enter height" GridPane.rowIndex="1" GridPane.columnIndex="2"
                   style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5;" />

        <Label text="Position:" GridPane.rowIndex="2" style="-fx-text-fill: white;" />
        <TextField fx:id="positionField" promptText="Enter position" GridPane.rowIndex="2"
                   style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5;" />

        <Label text="Number:" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-text-fill: white;" />
        <TextField fx:id="numberField" promptText="Enter number" GridPane.rowIndex="2" GridPane.columnIndex="2"
                   style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5;" />

        <Label text="Weekly Salary:" GridPane.rowIndex="3" style="-fx-text-fill: white;" />
        <TextField fx:id="weeklySalaryField" promptText="Enter weekly salary" GridPane.rowIndex="3"
                   style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5;" />

        <Label text="Base Price:" GridPane.rowIndex="3" GridPane.columnIndex="1" style="-fx-text-fill: white;" />
        <TextField fx:id="basePriceField" promptText="Enter base price" GridPane.rowIndex="3" GridPane.columnIndex="2"
                   style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5;" />

        <Label text="Club:" GridPane.rowIndex="4" style="-fx-text-fill: white;" />
        <TextField fx:id="clubField" promptText="Enter club" GridPane.rowIndex="4"
                   style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5;" />

        <Label text="On Sale:" GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-text-fill: white;" />
        <TextField fx:id="onSaleField" promptText="Enter Yes To Filter Out On Sale Players" GridPane.rowIndex="4" GridPane.columnIndex="2"
                   style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5;" />
    </GridPane>

    <!-- Filter Button -->
    <Button text="FILTER" onAction="#filterPlayers"
            style="-fx-background-color: #2A5298; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10 30; -fx-cursor: hand; -fx-border-color: white; -fx-border-radius: 10;" />

    <!-- TableView -->
    <TableView fx:id="playersTableView" prefHeight="600" prefWidth="750"
               style="-fx-background-color: rgba(0, 50, 100, 0.6); -fx-border-color: white; -fx-border-width: 2; -fx-border-radius: 10; -fx-font-family: 'Arial'; -fx-font-size: 12px; -fx-text-fill: white;">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <TableColumn text="Name" fx:id="nameColumn"
                     style="-fx-alignment: CENTER; -fx-text-fill: white;" />
        <TableColumn text="Country" fx:id="countryColumn"
                     style="-fx-alignment: CENTER; -fx-text-fill: white;" />
        <TableColumn text="Age" fx:id="ageColumn"
                     style="-fx-alignment: CENTER; -fx-text-fill: white;" />
        <TableColumn text="Height" fx:id="heightColumn"
                     style="-fx-alignment: CENTER; -fx-text-fill: white;" />
        <TableColumn text="Position" fx:id="positionColumn"
                     style="-fx-alignment: CENTER; -fx-text-fill: white;" />
        <TableColumn text="Number" fx:id="numberColumn"
                     style="-fx-alignment: CENTER; -fx-text-fill: white;" />
        <TableColumn text="Weekly Salary" fx:id="weeklySalaryColumn"
                     style="-fx-alignment: CENTER; -fx-text-fill: white;" />
        <TableColumn text="Base Price" fx:id="basePriceColumn"
                     style="-fx-alignment: CENTER; -fx-text-fill: white;" />
        <TableColumn text="Club" fx:id="clubColumn"
                     style="-fx-alignment: CENTER; -fx-text-fill: white;" />
        <TableColumn text="On Sale" fx:id="onSaleColumn"
                     style="-fx-alignment: CENTER; -fx-text-fill: white;" />
    </TableView>
</VBox>
