<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demonew.server.AddPlayerController" spacing="15" alignment="CENTER"
      style="-fx-background-color: linear-gradient(to bottom, #1E3C72, #2A5298); -fx-padding: 30;" prefWidth="650" prefHeight="700">

    <Label text="Add New Player" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />

    <TextField fx:id="nameField" promptText="Enter Player Name"
               style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5; -fx-border-width: 2; -fx-font-size: 16px; -fx-pref-width: 400;" />
    <TextField fx:id="countryField" promptText="Enter Country"
               style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5; -fx-border-width: 2; -fx-font-size: 16px; -fx-pref-width: 400;" />
    <TextField fx:id="ageField" promptText="Enter Age"
               style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5; -fx-border-width: 2; -fx-font-size: 16px; -fx-pref-width: 400;" />
    <TextField fx:id="heightField" promptText="Enter Height"
               style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5; -fx-border-width: 2; -fx-font-size: 16px; -fx-pref-width: 400;" />
    <TextField fx:id="clubField" promptText="Enter Club Name"
               style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5; -fx-border-width: 2; -fx-font-size: 16px; -fx-pref-width: 400;" />
    <TextField fx:id="positionField" promptText="Enter Position"
               style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5; -fx-border-width: 2; -fx-font-size: 16px; -fx-pref-width: 400;" />
    <TextField fx:id="jerseyNumberField" promptText="Enter Jersey Number (Optional)"
               style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5; -fx-border-width: 2; -fx-font-size: 16px; -fx-pref-width: 400;" />
    <TextField fx:id="weeklySalaryField" promptText="Enter Weekly Salary"
               style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5; -fx-border-width: 2; -fx-font-size: 16px; -fx-pref-width: 400;" />
    <TextField fx:id="basePriceField" promptText="Enter Base Price"
               style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5; -fx-border-width: 2; -fx-font-size: 16px; -fx-pref-width: 400;" />
    <TextField fx:id="onSaleField" promptText="Enter On Sale Status (true/false)"
               style="-fx-background-color: white; -fx-border-color: #2A5298; -fx-border-radius: 5; -fx-border-width: 2; -fx-font-size: 16px; -fx-pref-width: 400;" />

    <Button text="Add Player" onAction="#handleAddPlayer"
            style="-fx-background-color: #42A5F5; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-border-color: white; -fx-border-width: 2; -fx-border-radius: 5; -fx-pref-width: 200;" />
</VBox>
